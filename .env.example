# Copie para `.env` e ajuste. Usado pelo docker-compose.yml.
SERVER_PORT=4000
META_DB_USER=deepion
META_DB_PASSWORD=troque-esta-senha
META_DB_NAME=deepion_meta

# Cofre de segredos (criptografa credenciais dos data sources). DEFINA em produção.
META_ENCRYPTION_KEY=troque-por-uma-chave-forte

# Autenticação. Para uso pessoal/self-host, deixe AUTH_DISABLED=true.
# Em produção, defina AUTH_DISABLED=false e configure o OIDC do seu IdP.
AUTH_DISABLED=true
OIDC_ISSUER=
OIDC_AUDIENCE=
OIDC_JWKS_URI=
