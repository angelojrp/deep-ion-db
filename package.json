{
  "name": "deep-ion-db",
  "version": "0.3.0",
  "description": "IDE para bancos relacionais (estilo DBeaver) — Electron + React + TypeScript",
  "main": "./out/main/index.js",
  "author": "angelojrp@gmail.com",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck:server": "tsc --noEmit -p server/tsconfig.json",
    "typecheck:webapp": "tsc --noEmit -p web/tsconfig.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web && npm run typecheck:server && npm run typecheck:webapp",
    "web:build": "esbuild web/src/app.tsx --bundle --format=esm --outfile=web/public/app.js --jsx=automatic --minify",
    "server:dev": "tsx watch server/src/index.ts",
    "server:start": "tsx server/src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "npm run typecheck && npm run lint && npm run format:check",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "pack:dir": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "mcp:server": "tsx src/mcp/server.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/angelojrp/deep-ion-db.git"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/static": "^9.1.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-table": "^8.21.3",
    "better-sqlite3": "^12.11.1",
    "dompurify": "^3.4.11",
    "fastify": "^5.8.5",
    "jose": "^6.2.3",
    "marked": "^18.0.5",
    "monaco-editor": "^0.55.1",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql-formatter": "^15.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "electron": "^42.5.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "prettier": "^3.9.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "better-sqlite3@12.11.1": true,
    "electron@42.5.0": true,
    "esbuild@0.25.12": true,
    "esbuild@0.28.1": true,
    "@fastify/static@9.1.3": true
  }
}
